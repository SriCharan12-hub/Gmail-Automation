            {
              "id": "id-3",
              "name": "end",
              "value": "={{\n  (() => {\n    const [hour, minute] = $json.time.split(':').map(Number);\n    let newHour = hour + 1;\n    let newDate = $json.date;\n\n    if (newHour >= 24) {\n      newHour = newHour - 24;\n\n      const d = new Date($json.date);\n      d.setDate(d.getDate() + 1);\n      newDate = d.toISOString().split('T')[0];\n    }\n\n    return newDate + 'T' +\n      String(newHour).padStart(2, '0') +\n      ':' +\n      String(minute).padStart(2, '0') +\n      ':00';\n  })()\n}}",
              "type": "string"
